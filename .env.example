# ==============================================================================
# Smart Park & Ride - Environment Configuration Example
# Copy this file to '.env' and modify values for local development or production.
# ==============================================================================

# Database Configuration
POSTGRES_USER=parking_user
POSTGRES_PASSWORD=parking_pass
POSTGRES_DB=parking_db

# Database Connection URL (PostgreSQL with asyncpg driver)
# Change localhost to 'postgres' if running via docker-compose directly
DATABASE_URL=postgresql+asyncpg://parking_user:parking_pass@localhost:5432/parking_db

# Redis Connection URL
REDIS_URL=redis://localhost:6379

# Admin & Operator Portal Credentials
# IMPORTANT: Passwords must be bcrypt hashes, NOT plaintext!
# Generate one with: python -c "from services.password_utils import hash_password; print(hash_password('your_password'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=$2b$12$UJhGUpVI/h1hZFv1V1Z2POEM8eMb/ArTKkTgEV5KqVlSFmmQvU.u.
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=$2b$12$rPqDggdoLRozOPeOpkiDN.WhJvuQLGW7TNhXwHtBiWWsLo9Jic2D.

# Comma-separated list of allowed CORS origins for the backend.
# Defaults match development local servers.
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5173,http://127.0.0.1:5173
